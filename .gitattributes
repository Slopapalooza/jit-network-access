# Authored on Windows, executed on Linux (Docker/OpenResty). Force LF so shell
# scripts and Lua/config never get CRLF line endings that would break at runtime.
* text=auto eol=lf

*.sh    text eol=lf
*.lua   text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.conf  text eol=lf
*.json  text eol=lf
*.md    text eol=lf

# Binary
*.png binary
*.jpg binary
*.gz  binary
