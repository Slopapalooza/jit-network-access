{
  "manifest_version": 3,
  "name": "JIT Network Access",
  "version": "0.2.0",
  "description": "Silently answers the JIT Network Access knock so protected origins open transparently.",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-ancestors 'none'"
  },
  "permissions": ["storage", "webNavigation", "webRequest", "tabs"],
  "optional_host_permissions": ["https://*/*"],
  "background": { "service_worker": "src/sw.js", "type": "module" },
  "action": { "default_popup": "popup.html", "default_title": "JIT Network Access" },
  "options_page": "options.html",
  "web_accessible_resources": [
    { "resources": ["enroll.html"], "matches": ["https://*/*"] }
  ],
  "icons": {}
}
